{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "routes": [
    {
      "src": "^/static/(.*)$",
      "dest": "/static/$1",
      "headers": {
        "cache-control": "public, max-age=31536000, s-maxage=31536000"
      }
    },
    {
      "src": "^/(.*\\.[a-z0-9]+)$",
      "dest": "/$1"
    },
    {
      "src": "^/(.*)$",
      "dest": "/index.html"
    }
  ]
}